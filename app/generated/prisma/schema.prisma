// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  GURU
  SISWA
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  password      String
  role          Role          @default(SISWA)
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime      @default(now())
  // Relation for Teacher: classes they teach
  teaching      SchoolClass[] @relation("TeacherClasses")
  enrollments   Enrollment[]
  materials     Material[]    @relation("UserMaterials")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SchoolClass {
  id          String       @id @default(uuid())
  name        String
  createdAt   DateTime     @default(now())
  materials   Material[]
  subjectId   String
  teacherId   String
  subject     Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher     User         @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
}

model Material {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  fileUrl     String?
  classId     String
  createdById String
  createdAt   DateTime @default(now())

  class     SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdBy User        @relation("UserMaterials", fields: [createdById], references: [id])

  @@index([classId])
  @@index([createdById])
}

model Subject {
  id          String        @id @default(uuid())
  name        String
  code        String        @unique
  description String?
  createdAt   DateTime      @default(now())
  classes     SchoolClass[]
}

model Enrollment {
  id        String   @id @default(uuid())
  studentId String
  classId   String
  createdAt DateTime @default(now())

  student User        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([studentId, classId])
}
